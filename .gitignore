# Generated by Cargo
# will have compiled files and executables
/target/

# Remove Cargo.lock from gitignore if creating a library
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows build files
*.pdb

# Profiling output
*.profraw
*.profdata

# Binaries
/*.exe
/*.dll
/*.dylib
/*.so
/*.lib
/*.a

# Editor temporary files
*~
*.

# IDE directories
.idea/
.vscode/

# Generated by cargo-cult
cargo-cult/

# Logs
*.log

# Misc
.DS_Store

# Secrets
.env
.env.*

# Generated runtime config
config.yaml
